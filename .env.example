# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=prod

# MySQL connection (used in docker-compose and application-prod.properties)
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/movies_db
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=changeme
SPRING_DATABASE=movies_db

# JWT secret key (use a long random string in production)
JWT_SECRET=your-jwt-secret-key-change-me

# Frontend URL (for OAuth2 redirects)
FRONTEND_BASE_URL=http://localhost:5173

# Google OAuth2 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
